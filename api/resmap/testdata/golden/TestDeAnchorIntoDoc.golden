apiVersion: apps/v1
kind: Deployment
metadata:
  name: probes-test
spec:
  template:
    spec:
      livenessProbe:
        failureThreshold: 3
        httpGet:
          path: /health
          port: http
        periodSeconds: 5
        timeoutSeconds: 3
      readinessProbe:
        failureThreshold: 3
        httpGet:
          path: /health
          port: http
        periodSeconds: 5
        timeoutSeconds: 3
