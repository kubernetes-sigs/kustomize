apiVersion: apps/v1
kind: Deployment
metadata:
  name: service-a
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/component: service-a
  template:
    metadata:
      labels:
        app.kubernetes.io/component: service-a
    spec:
      containers:
      - env:
        - name: REDIRECT_URI
          value: http://new-service-b.k8s.com:80/oauth_redir
        image: repository/service-a:v1
        imagePullPolicy: Always
        name: service-b
        ports:
        - containerPort: 8080
---
apiVersion: v1
kind: Service
metadata:
  labels:
    app.kubernetes.io/component: service-a
  name: service-a
spec:
  ports:
  - port: 8080
  selector:
    app.kubernetes.io/component: service-a
  type: LoadBalancer
---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: service-a
spec:
  rules:
  - host: new-service-a.k8s.com
    http:
      paths:
      - backend:
          service:
            name: service-a
            port:
              number: 8080
        path: /
        pathType: Prefix
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: service-b
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/component: service-b
  template:
    metadata:
      labels:
        app.kubernetes.io/component: service-b
    spec:
      containers:
      - env:
        - name: REDIRECT_URI
          value: http://new-service-a.k8s.com:80/oauth_redir
        image: repository/service-b:v1
        imagePullPolicy: Always
        name: service-b
        ports:
        - containerPort: 8080
---
apiVersion: v1
kind: Service
metadata:
  labels:
    app.kubernetes.io/component: service-b
  name: service-b
spec:
  ports:
  - port: 8080
  selector:
    app.kubernetes.io/component: service-b
  type: LoadBalancer
---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: service-b
spec:
  rules:
  - host: new-service-b.k8s.com
    http:
      paths:
      - backend:
          service:
            name: service-b
            port:
              number: 8080
        path: /
        pathType: Prefix
