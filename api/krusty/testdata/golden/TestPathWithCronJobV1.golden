apiVersion: batch/v1
kind: CronJob
metadata:
  name: test
spec:
  concurrencyPolicy: Forbid
  jobTemplate:
    spec:
      backoffLimit: 3
      template:
        spec:
          containers:
          - command:
            - /bin/sh
            - -c
            - echo "test"
            env:
            - name: ENV_NEW
              value: val_new
            - name: ENV1
              value: val1
            - name: ENV2
              value: val2
            - name: ENV3
              value: val3
            image: bash
            name: test
          restartPolicy: Never
  schedule: 5 10 * * 1
